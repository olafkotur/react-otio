{
  "name": "react-otio",
  "version": "0.0.5",
  "description": "Reusable react components and hooks",
  "source": "src/index.ts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": "https://github.com/olafkotur/react-otio",
  "author": "olafkotur",
  "license": "MIT",
  "private": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "babel": {
    "presets": [
      "@babel/preset-react"
    ]
  },
  "scripts": {
    "build": "rm -rf dist && mkdir dist &&  babel src -d dist --copy-files",
    "start": "rollup -c -w",
    "publish": "npm publish --access public"
  },
  "dependencies": {
    "react": "^18.2.0",
    "styled-components": "^6.0.5"
  },
  "devDependencies": {
    "@babel/cli": "^7.22.9",
    "@babel/preset-react": "^7.22.5",
    "@types/react": "^18.2.15",
    "prettier": "^3.0.0",
    "prettier-plugin-organize-imports": "^3.2.3",
    "typescript": "^5.1.6"
  }
}
